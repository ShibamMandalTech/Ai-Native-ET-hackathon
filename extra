def _run_gemini(prompt: str) -> dict:
    api_key = settings.GEMINI_API_KEY or os.getenv("GEMINI_API_KEY")
    if not api_key:
        raise RuntimeError("Missing GEMINI_API_KEY")

    headers = {"Content-Type": "application/json"}
    payload = {
        "contents": [{"parts": [{"text": prompt}]}],
        "generationConfig": {
            "temperature": 0.2,
            "responseMimeType": "application/json",
        },
    }

    had_404 = False
    had_429 = False
    had_auth_error = False
    seen_models = set()

    for model in GEMINI_MODEL_CANDIDATES:
        if not model or model in seen_models:
            continue
        seen_models.add(model)

        url = f"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={api_key}"
        response = requests.post(url, headers=headers, json=payload, timeout=12)

        if response.status_code == 404:
            had_404 = True
            continue
        if response.status_code == 429:
            had_429 = True
            continue
        if response.status_code in (401, 403):
            had_auth_error = True
            continue

        response.raise_for_status()
        data = response.json()
        candidates = data.get("candidates", [])
        if not candidates:
            raise ValueError("No response from Gemini")

        text = candidates[0]["content"]["parts"][0]["text"].strip()
        return _parse_json_text(text)

    if had_auth_error:
        raise RuntimeError("Gemini API key is invalid or lacks required permissions")
    if had_429:
        raise RuntimeError("Gemini API quota or rate limit exceeded")
    if had_404:
        raise RuntimeError("Configured Gemini model is unavailable for this key/project")

    raise RuntimeError("No supported Gemini model available")


def _reason_from_error(message: str, provider_hint: str = "configured") -> str:
    lowered = (message or "").lower()
    if "quota" in lowered or "rate limit" in lowered or "429" in lowered:
        return f"Agentic AI request limit reached for the {provider_hint} provider. Retry later or use another provider/key."
    if "invalid" in lowered or "permission" in lowered or "401" in lowered or "403" in lowered:
        return f"{provider_hint.title()} API key is invalid or missing required permissions for model inference."
    if "unavailable" in lowered or "not found" in lowered or "404" in lowered:
        return f"Configured model is unavailable for the {provider_hint} provider/key."
    if "missing groq_api_key" in lowered:
        return "Agentic AI Supervisor disabled (Missing GROQ_API_KEY). Proceed with standard manual review of logs."
    if "missing gemini_api_key" in lowered:
        return "Agentic AI Supervisor disabled (Missing GEMINI_API_KEY). Proceed with standard manual review of logs."
    if "missing openai_api_key" in lowered:
        return "Agentic AI Supervisor disabled (Missing OPENAI_API_KEY). Proceed with standard manual review of logs."
    return "Agentic AI failed to process the request due to provider availability, network, or response parsing issues."


def _normalize_report(report: dict) -> dict:
    probability = report.get("probability_cheating", "Unknown")
    reasoning = report.get("reasoning", "No reasoning provided by model.")
    action = report.get("recommended_action", "Manual Review Required")

    return {
        "probability_cheating": probability,
        "reasoning": reasoning,
        "recommended_action": action,
    }

def generate_supervisor_report(events: list, violations: int, coding_scores: dict, exam_duration: int) -> dict:
    """
    Acts as an AI Proctoring Supervisor. Analyzes the raw logs generated by the client 
    (MediaPipe WebAssembly) and intelligently synthesizes them into a human-readable 
    assessment report preventing strict false positives.
    """
    prompt = _build_supervisor_prompt(events, violations, coding_scores, exam_duration)
    provider = (settings.AI_PROVIDER or "auto").strip().lower()

    openai_key_present = bool(settings.OPENAI_API_KEY or os.getenv("OPENAI_API_KEY"))
    groq_key_present = bool(settings.GROQ_API_KEY or os.getenv("GROQ_API_KEY"))
    gemini_key_present = bool(settings.GEMINI_API_KEY or os.getenv("GEMINI_API_KEY"))

    if provider == "openai":
        if not openai_key_present:
            return {
                "probability_cheating": "Unknown",
                "reasoning": "Agentic AI Supervisor disabled (Missing OPENAI_API_KEY). Proceed with standard manual review of logs.",
                "recommended_action": "Manual Review Required",
            }
        try:
            return _normalize_report(_run_openai(prompt))
        except Exception as e:
            return {
                "probability_cheating": "Error",
                "reasoning": _reason_from_error(str(e), "openai"),
                "recommended_action": "Manual Review Required",
            }

    if provider == "groq":
        if not groq_key_present:
            return {
                "probability_cheating": "Unknown",
                "reasoning": "Agentic AI Supervisor disabled (Missing GROQ_API_KEY). Proceed with standard manual review of logs.",
                "recommended_action": "Manual Review Required",
            }
        try:
            return _normalize_report(_run_groq(prompt))
        except Exception as e:
            return {
                "probability_cheating": "Error",
                "reasoning": _reason_from_error(str(e), "groq"),
                "recommended_action": "Manual Review Required",
            }

    if provider == "gemini":
        if not gemini_key_present:
            return {
                "probability_cheating": "Unknown",
                "reasoning": "Agentic AI Supervisor disabled (Missing GEMINI_API_KEY). Proceed with standard manual review of logs.",
                "recommended_action": "Manual Review Required",
            }
        try:
            return _normalize_report(_run_gemini(prompt))
        except Exception as e:
            return {
                "probability_cheating": "Error",
                "reasoning": _reason_from_error(str(e), "gemini"),
                "recommended_action": "Manual Review Required",
            }

    # auto mode: prefer OpenAI, then Groq, then Gemini.
    errors = []

    if openai_key_present:
        try:
            return _normalize_report(_run_openai(prompt))
        except Exception as e:
            errors.append(str(e))

    if groq_key_present:
        try:
            return _normalize_report(_run_groq(prompt))
        except Exception as e:
            errors.append(str(e))

    if gemini_key_present:
        try:
            return _normalize_report(_run_gemini(prompt))
        except Exception as e:
            errors.append(str(e))

    if not openai_key_present and not groq_key_present and not gemini_key_present:
        return {
            "probability_cheating": "Unknown",
            "reasoning": "Agentic AI Supervisor disabled (Missing OPENAI_API_KEY, GROQ_API_KEY, and GEMINI_API_KEY). Proceed with standard manual review of logs.",
            "recommended_action": "Manual Review Required",
        }

    return {
        "probability_cheating": "Error",
        "reasoning": _reason_from_error(" | ".join(errors), "configured"),
        "recommended_action": "Manual Review Required",
    }